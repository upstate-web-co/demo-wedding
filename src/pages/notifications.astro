---
/**
 * Notification mockup — "phone reveal" for the Wedding Florist ad.
 * Script: Split between a couple exploring the site and a planner finishing setup. Both check phone.
 * Tagline: UWC: where it's all smiles.
 */
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Notifications — Lark & Bower</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            sage: '#8B9F82',
            blush: '#D4A0A0',
            ivory: '#1A1916',
          }
        }
      }
    }
  </script>
</head>
<body class="bg-ivory min-h-screen text-white">
  <!-- Status Bar Mockup -->
  <div class="flex items-center justify-between px-6 py-2 text-xs text-white/60">
    <span>6:15 PM</span>
    <div class="flex items-center gap-1"><span>5G</span><span>📶</span><span>🔋 58%</span></div>
  </div>

  <!-- App Header -->
  <div class="px-6 pt-4 pb-6">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm text-white/50">Good evening</p>
        <h1 class="text-2xl font-bold">Lark & Bower</h1>
      </div>
      <div class="relative">
        <div class="w-10 h-10 rounded-full bg-sage/20 flex items-center justify-center text-lg">💐</div>
        <div class="absolute -top-1 -right-1 w-5 h-5 rounded-full bg-red-500 flex items-center justify-center text-[10px] font-bold">11</div>
      </div>
    </div>
  </div>

  <!-- Summary Cards -->
  <div class="px-6 grid grid-cols-3 gap-3 mb-6">
    <div class="bg-white/5 border border-white/10 rounded-xl p-3 text-center">
      <p class="text-2xl font-bold text-sage">3</p>
      <p class="text-[10px] text-white/50 mt-1">Inquiries</p>
    </div>
    <div class="bg-white/5 border border-white/10 rounded-xl p-3 text-center">
      <p class="text-2xl font-bold text-green-400">$8,500</p>
      <p class="text-[10px] text-white/50 mt-1">Estate Inquiry</p>
    </div>
    <div class="bg-white/5 border border-white/10 rounded-xl p-3 text-center">
      <p class="text-2xl font-bold text-blush">5</p>
      <p class="text-[10px] text-white/50 mt-1">AI Chats</p>
    </div>
  </div>

  <!-- Timeline -->
  <div class="px-6">
    <h2 class="text-sm font-semibold text-white/40 uppercase tracking-wider mb-4">While you were away</h2>
    <div class="space-y-3">
      <div class="bg-white/5 border border-white/10 rounded-xl p-4">
        <div class="flex items-start justify-between">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-sage/20 flex items-center justify-center text-sm">💒</div>
            <div>
              <p class="text-sm font-medium">New inquiry: June wedding, 180 guests</p>
              <p class="text-xs text-white/40">Estate Package · $8,500 estimated</p>
            </div>
          </div>
          <span class="text-[10px] text-white/30">3m ago</span>
        </div>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-xl p-4">
        <div class="flex items-start justify-between">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-blue-500/20 flex items-center justify-center text-sm">💬</div>
            <div>
              <p class="text-sm font-medium">AI walked Emma & Jake through package comparison</p>
              <p class="text-xs text-white/40">They selected the Garden Package</p>
            </div>
          </div>
          <span class="text-[10px] text-white/30">18m ago</span>
        </div>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-xl p-4">
        <div class="flex items-start justify-between">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-blush/20 flex items-center justify-center text-sm">✨</div>
            <div>
              <p class="text-sm font-medium">Couple asked about add-ons — AI suggested 3</p>
              <p class="text-xs text-white/40">They selected all three · ceremony arch, boutonnieres, petal aisle</p>
            </div>
          </div>
          <span class="text-[10px] text-white/30">30m ago</span>
        </div>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-xl p-4">
        <div class="flex items-start justify-between">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-blue-500/20 flex items-center justify-center text-sm">💬</div>
            <div>
              <p class="text-sm font-medium">AI answered "Do you do destination weddings?"</p>
              <p class="text-xs text-white/40">Shared travel policy · visitor bookmarked the page</p>
            </div>
          </div>
          <span class="text-[10px] text-white/30">45m ago</span>
        </div>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-xl p-4">
        <div class="flex items-start justify-between">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-sage/20 flex items-center justify-center text-sm">📅</div>
            <div>
              <p class="text-sm font-medium">2 more consultation requests for fall dates</p>
              <p class="text-xs text-white/40">October & November · both requesting quotes</p>
            </div>
          </div>
          <span class="text-[10px] text-white/30">1h ago</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Summary -->
  <div class="px-6 py-8 mt-4">
    <div class="bg-sage/10 border border-sage/20 rounded-xl p-5 text-center">
      <p class="text-sage text-sm font-medium">3 couples found their perfect florist.</p>
      <p class="text-white/50 text-xs mt-1">You were setting up someone else's perfect day.</p>
      <p class="text-white/30 text-[10px] mt-3">3 inquiries · 5 AI conversations · $8,500 estimated</p>
    </div>
  </div>

  <!-- UWC Branding -->
  <div class="fixed bottom-0 left-0 right-0 bg-gradient-to-t from-ivory via-ivory/80 to-transparent py-6 px-6">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-white text-lg font-bold">UWC</p>
        <p class="text-sage text-sm">Where it's all smiles.</p>
      </div>
      <p class="text-white/30 text-xs">upstate-web.com</p>
    </div>
  </div>
</body>
</html>
